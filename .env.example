# Copy required values into your local shell or a private .env file.
# Never commit real secrets, tokens, private endpoints, or patient information.

# Ollama local API
QADAMCARE_OLLAMA_URL=http://127.0.0.1:11434/api/chat
QADAMCARE_OLLAMA_TEXT_MODEL=qwen2.5:3b
QADAMCARE_OLLAMA_VISION_MODEL=qwen2.5vl:3b
QADAMCARE_TEXT_CONTEXT=4096
QADAMCARE_VISION_CONTEXT=4096

# Optional Ollama CPU-only settings for Windows PowerShell are normally set
# in the shell before `ollama serve`, not read automatically from this file:
# OLLAMA_LLM_LIBRARY=cpu_avx2
# CUDA_VISIBLE_DEVICES=-1
# OLLAMA_CONTEXT_LENGTH=4096
